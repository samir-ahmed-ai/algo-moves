{
  "name": "algo-moves",
  "private": true,
  "version": "0.1.0",
  "description": "Step-through visual replay engine for ~400 coding-interview problems — LeetCode, HackerRank, and original plugins with Go solutions, Code Studio, and mobile drill mode.",
  "license": "AGPL-3.0",
  "type": "module",
  "keywords": [
    "algorithms",
    "leetcode",
    "hackerrank",
    "interview-prep",
    "visualization",
    "react",
    "typescript",
    "go"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run prebuild && tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --incremental false",
    "new-problem": "node scripts/new-problem.mjs",
    "new-effect": "node scripts/new-effect.mjs",
    "import-prep": "node scripts/import-prep.mjs && npm run build-problem-briefs",
    "import-problems": "node scripts/import-problems.mjs",
    "scaffold-prep-sim": "node scripts/scaffold-prep-simulator.mjs",
    "check-prep-sim-coverage": "node scripts/check-prep-simulator-coverage.mjs",
    "check-prep-quiz-coverage": "node scripts/check-prep-quiz-coverage.mjs",
    "generate-prep-practice-quiz": "node scripts/generate-prep-practice-quiz.mjs",
    "check-mobile-decks": "node scripts/check-mobile-decks.mjs",
    "check-orphans": "node scripts/check-orphans.mjs",
    "generate-themes": "node scripts/generate-themes.mjs",
    "check-plugin-typography": "node scripts/lint-plugin-typography.mjs",
    "check-simulators": "node scripts/check-simulators.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "check:quiz-labels": "vitest run src/lib/quizChoiceFormat.test.ts src/plugins/integrity.test.ts",
    "build-plugin-meta": "vite-node scripts/build-plugin-meta.mts",
    "check-plugin-meta": "vite-node scripts/build-plugin-meta.mts -- --check",
    "build-problem-briefs": "vite-node scripts/build-problem-briefs.mts",
    "check-problem-briefs": "vite-node scripts/build-problem-briefs.mts -- --check",
    "export-content-sql": "vite-node scripts/export-content-sql.mts",
    "check-content-sql": "vite-node scripts/export-content-sql.mts -- --check",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:lint": "eslint src",
    "check:all": "npm run check:boundaries && npm run check-simulators && npm run check-prep-sim-coverage && npm run check-prep-quiz-coverage && npm run check-plugin-typography && npm run check:tokens && npm run check:quiz-labels && npm run check-plugin-meta && npm run check-problem-briefs && npm run check-content-sql && npm run check:lint",
    "draft-quiz-from-frames": "node scripts/draft-quiz-from-frames.mjs",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "prebuild": "npm run generate-pwa-icons",
    "test": "vitest run && npm run check-orphans"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.10.3",
    "@codemirror/legacy-modes": "^6.4.1",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "@dagrejs/dagre": "^3.0.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@xyflow/react": "^12.11.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.456.0",
    "lz-string": "^1.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/lz-string": "^1.3.34",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "postcss": "^8.4.47",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.8"
  }
}
