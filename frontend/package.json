{
  "name": "algo-moves",
  "private": true,
  "version": "0.1.0",
  "description": "Step-through visual replay engine for ~400 coding-interview problems — LeetCode, HackerRank, and original plugins with Go solutions, Code Studio, and mobile drill mode.",
  "license": "AGPL-3.0",
  "type": "module",
  "keywords": [
    "algorithms",
    "leetcode",
    "hackerrank",
    "interview-prep",
    "visualization",
    "react",
    "typescript",
    "go"
  ],
  "scripts": {
    "dev": "vite",
    "hocuspocus": "node scripts/hocuspocus-server.mjs",
    "build": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "build:analyze": "ANALYZE=1 vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --incremental false",
    "new-problem": "node scripts/new-problem.mjs",
    "new-effect": "node scripts/new-effect.mjs",
    "import-prep": "node scripts/import-prep.mjs && npm run build-problem-briefs",
    "import-problems": "node scripts/import-problems.mjs",
    "scaffold-prep-sim": "node scripts/scaffold-prep-simulator.mjs",
    "check-prep-sim-coverage": "node scripts/check-prep-simulator-coverage.mjs",
    "check-prep-quiz-coverage": "node scripts/check-prep-quiz-coverage.mjs",
    "check-prep-sim-quality": "node scripts/check-prep-sim-quality.mjs",
    "generate-prep-practice-quiz": "node scripts/generate-prep-practice-quiz.mjs",
    "check-mobile-decks": "node scripts/check-mobile-decks.mjs",
    "check-orphans": "node scripts/check-orphans.mjs",
    "generate-themes": "node scripts/generate-themes.mjs",
    "check-plugin-typography": "node scripts/lint-plugin-typography.mjs",
    "check-shell-typography": "node scripts/check-shell-typography.mjs",
    "check:lighthouse-budget": "node scripts/lighthouse-budget.mjs",
    "check-simulators": "node scripts/check-simulators.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "check:quiz-labels": "NODE_OPTIONS=--localstorage-file=.node-localstorage vitest run src/lib/quizChoiceFormat.test.ts src/plugins/integrity.test.ts",
    "build-plugin-meta": "NODE_OPTIONS=--localstorage-file=.node-localstorage vite-node scripts/build-plugin-meta.mts",
    "check-plugin-meta": "NODE_OPTIONS=--localstorage-file=.node-localstorage vite-node scripts/build-plugin-meta.mts -- --check",
    "build-problem-briefs": "NODE_OPTIONS=--localstorage-file=.node-localstorage vite-node scripts/build-problem-briefs.mts",
    "check-problem-briefs": "NODE_OPTIONS=--localstorage-file=.node-localstorage vite-node scripts/build-problem-briefs.mts -- --check",
    "export-content-sql": "NODE_OPTIONS=--localstorage-file=.node-localstorage vite-node scripts/export-content-sql.mts",
    "check-content-sql": "NODE_OPTIONS=--localstorage-file=.node-localstorage vite-node scripts/export-content-sql.mts -- --check",
    "check:content": "NODE_OPTIONS=--localstorage-file=.node-localstorage run-p --print-label check-prep-sim-coverage check-prep-quiz-coverage check-prep-sim-quality check:quiz-labels",
    "check:design": "run-p --print-label check-plugin-typography check-shell-typography check:lighthouse-budget check:tokens",
    "check:generated": "NODE_OPTIONS=--localstorage-file=.node-localstorage run-p --print-label check-plugin-meta check-problem-briefs check-content-sql",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:circular": "node scripts/check-circular.mjs",
    "check:lint": "eslint src",
    "check:knip": "knip --dependencies --files",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{mjs,mts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{mjs,mts,js}\"",
    "test:coverage": "NODE_OPTIONS=--localstorage-file=.node-localstorage vitest run --coverage",
    "check:all": "NODE_OPTIONS=--localstorage-file=.node-localstorage run-p --print-label check:boundaries check:circular check-simulators check:content check:design check:generated check:lint",
    "draft-quiz-from-frames": "node scripts/draft-quiz-from-frames.mjs",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "prebuild": "npm run generate-pwa-icons",
    "test": "NODE_OPTIONS=--localstorage-file=.node-localstorage vitest run && npm run check-orphans",
    "prepare": "cd .. && husky"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.10.3",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@hocuspocus/provider": "^4.3.0",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@shikijs/langs": "^4.3.1",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "diff": "^9.0.0",
    "elkjs": "^0.11.1",
    "gifenc": "^1.0.3",
    "html-to-image": "^1.11.13",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.456.0",
    "lz-string": "^1.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^4.3.1",
    "tailwind-merge": "^2.5.4",
    "ts-fsrs": "^5.4.1",
    "yjs": "^13.6.31",
    "zustand": "^4.5.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,mjs,mts,js}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@excalidraw/excalidraw": {
      "nanoid": "^3.3.15"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "^5.1.16"
    },
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hocuspocus/server": "^3.4.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/lz-string": "^1.3.34",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.4.47",
    "prettier": "^3.9.4",
    "rollup-plugin-visualizer": "^6.0.11",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.1.3",
    "vite-node": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
