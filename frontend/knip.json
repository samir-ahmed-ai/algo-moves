  "entry": ["scripts/**/*.{mjs,mts}", "../.husky/pre-commit"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{mjs,mts}"],
  "ignore": [
    "src/components/board/index.ts",
    "src/components/code/index.ts",
