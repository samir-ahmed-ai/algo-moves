# Realtime game server for the two-player Games arcade.
#
# Leave this UNSET to use the zero-config LAN default: the frontend connects to
# ws://<the-host-you-opened-the-site-on>:8080. Run the backend with
# `make backend-dev` (from repo root) and open the site on your machine's LAN
# IP from both phones/iPads.
#
# Set it to your deployed server for play over the internet (http→ws, https→wss
# is derived automatically):
# VITE_GAMES_SERVER_URL=https://games.your-domain.com
#
# Production — set on the Railway frontend service (build-time ARGs):
#   VITE_GAMES_SERVER_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}
#   VITE_HOCUSPOCUS_URL=wss://${{hocuspocus.RAILWAY_PUBLIC_DOMAIN}}

# Arcade persistence (profiles, leaderboards, match history) is served by the
# backend at /api/* when DATABASE_URL points at Postgres. On Railway, add a
# Postgres plugin and reference it from the backend service — no frontend env
# vars needed for the database. See db/README.md.
#
# --- Canvas Yjs collaboration (Hocuspocus) ---
# Transport is ON when VITE_HOCUSPOCUS_URL is set. Subdoc transport defaults ON
# (opt-out: VITE_YJS_SUBDOC_TRANSPORT=false).
#
# Local full collab stack: make dev-collab
# VITE_HOCUSPOCUS_URL=ws://localhost:1234
#
# Production (Railway): deploy services/hocuspocus, then set on the frontend:
#   VITE_HOCUSPOCUS_URL=wss://${{hocuspocus.RAILWAY_PUBLIC_DOMAIN}}
