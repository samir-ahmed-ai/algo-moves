# Game server (optional — LAN works without these)
# PORT=8080
# ALLOWED_ORIGINS=https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}
#   Also enables cross-site session cookies (SameSite=None; Secure) for credentialed API calls.
# COOKIE_CROSS_SITE=true   # optional override when ALLOWED_ORIGINS is unset

# Arcade persistence — Railway Postgres (reference ${{Postgres.DATABASE_URL}})
# DATABASE_URL=postgres://user:pass@host:5432/railway?sslmode=require
# RUN_MIGRATIONS=true   # apply schema + achievement seed on startup (true/1)
# RUN_CONTENT_SEED=true # reload learning catalog from embedded export (true/1)
#   The embedded content seed is generated by: npm --prefix frontend run export-content-sql
# PLATFORM_ADMIN_EMAIL=admin@example.com
# PLATFORM_ADMIN_PASSWORD=change-me-on-deploy   # min 8 chars; creates/syncs admin on startup
# PLATFORM_ADMIN_DISPLAY_NAME=Platform Admin    # optional

# Per-user API key storage (required to save user OpenAI keys at rest)
# Generate: openssl rand -base64 32
# SECRETS_ENCRYPTION_KEY=

# Resume template creator — optional server fallback when user has no key
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o   # optional, defaults to gpt-4o
